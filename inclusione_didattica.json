'use client'
import { useState, useEffect, useRef } from 'react'

const LIBRERIA_BASE = 'https://raw.githubusercontent.com/iacir/lessonynet-libreria/main/'

interface FileLibreria {
  nome: string
  file: string
  emoji: string
}

interface Fonte {
  id: string
  nome: string
  emoji: string
  descrizione: string
  colore: string
}

interface Messaggio {
  ruolo: 'utente' | 'assistente'
  testo: string
  loading?: boolean
}

const FONTI: Fonte[] = [
  { id: 'libreria', nome: 'Libreria LessonyNet', emoji: '📚', descrizione: 'Programmazioni curricolari e guide didattiche', colore: '#1e3a6e' },
  { id: 'wikipedia', nome: 'Wikipedia', emoji: '🌐', descrizione: 'Enciclopedia libera italiana', colore: '#2e7d32' },
  { id: 'wiktionary', nome: 'Wiktionary', emoji: '📖', descrizione: 'Dizionario e definizioni italiane', colore: '#1565c0' },
  { id: 'wikiquote', nome: 'Wikiquote', emoji: '💬', descrizione: 'Citazioni di autori e personaggi storici', colore: '#6a1b9a' },
  { id: 'wikisource', nome: 'Wikisource', emoji: '📜', descrizione: 'Testi letterari italiani classici', colore: '#b71c1c' },
  { id: 'europeana', nome: 'Europeana', emoji: '🏛️', descrizione: 'Patrimonio culturale e artistico europeo', colore: '#e65100' },
]

function getEmoji(file: string): string {
  if (file.includes('primaria')) return '🏫'
  if (file.includes('secondaria')) return '📚'
  if (file.includes('guida')) return '📖'
  if (file.includes('icf')) return '♿'
  return '📄'
}

// ═══════════════════════════════════════
// FUNZIONI DI RICERCA
// ═══════════════════════════════════════

async function cercaWikipedia(query: string): Promise<string> {
  try {
    const q = encodeURIComponent(query)
    const r = await fetch(`https://it.wikipedia.org/api/rest_v1/page/summary/${q}`)
    if (r.ok) {
      const d = await r.json()
      if (d.extract) {
        const url = d.content_urls?.desktop?.page || ''
        return `🌐 **${d.title}** *(Wikipedia)*:\n${d.extract.slice(0, 600)}${url ? `\n\n🔗 [Leggi su Wikipedia](${url})` : ''}\n\n_Fonte: Wikipedia_`
      }
    }
    const r2 = await fetch(`https://it.wikipedia.org/w/api.php?action=query&list=search&srsearch=${q}&format=json&origin=*&utf8=1&srlimit=1`)
    const d2 = await r2.json()
    const primo = d2?.query?.search?.[0]
    if (primo) {
      const r3 = await fetch(`https://it.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(primo.title)}`)
      const d3 = await r3.json()
      const url = d3.content_urls?.desktop?.page || ''
      return `🌐 **${d3.title || primo.title}** *(Wikipedia)*:\n${(d3.extract || '').slice(0, 600)}${url ? `\n\n🔗 [Leggi su Wikipedia](${url})` : ''}\n\n_Fonte: Wikipedia_`
    }
  } catch {}
  return 'Nessun risultato trovato su Wikipedia.'
}

async function cercaWiktionary(query: string): Promise<string> {
  try {
    const q = encodeURIComponent(query)
    // Prima prova la API rest
    const r = await fetch(`https://it.wiktionary.org/api/rest_v1/page/summary/${q}`)
    if (r.ok) {
      const d = await r.json()
      if (d.extract) {
        return `📖 **${d.title}** *(Wiktionary — Definizione)*:\n${d.extract.slice(0, 500)}\n\n_Fonte: Wiktionary_`
      }
    }
    // Fallback con search API
    const r2 = await fetch(`https://it.wiktionary.org/w/api.php?action=query&list=search&srsearch=${q}&format=json&origin=*&utf8=1&srlimit=1`)
    const d2 = await r2.json()
    const primo = d2?.query?.search?.[0]
    if (primo) {
      const r3 = await fetch(`https://it.wiktionary.org/api/rest_v1/page/summary/${encodeURIComponent(primo.title)}`)
      if (r3.ok) {
        const d3 = await r3.json()
        if (d3.extract) {
          return `📖 **${d3.title}** *(Wiktionary — Definizione)*:\n${d3.extract.slice(0, 500)}\n\n_Fonte: Wiktionary_`
        }
      }
      return `📖 **${primo.title}** *(Wiktionary)*:\n${primo.snippet?.replace(/<[^>]+>/g, '') || ''}\n\n_Fonte: Wiktionary_`
    }
  } catch {}
  return 'Nessuna definizione trovata su Wiktionary.'
}

async function cercaWikiquote(query: string): Promise<string> {
  try {
    const q = encodeURIComponent(query)
    const r = await fetch(`https://it.wikiquote.org/w/api.php?action=query&titles=${q}&prop=extracts&exintro=1&format=json&origin=*&utf8=1`)
    const d = await r.json()
    const pages = d?.query?.pages || {}
    const page = Object.values(pages)[0] as any
    if (page && page.extract && !page.missing) {
      const testo = page.extract.replace(/<[^>]+>/g, '').slice(0, 500)
      return `💬 **${page.title}** *(Wikiquote — Citazioni)*:\n${testo}\n\n🔗 [Vedi tutte le citazioni](https://it.wikiquote.org/wiki/${q})\n\n_Fonte: Wikiquote_`
    }
    // Fallback search
    const r2 = await fetch(`https://it.wikiquote.org/w/api.php?action=query&list=search&srsearch=${q}&format=json&origin=*&utf8=1&srlimit=1`)
    const d2 = await r2.json()
    const primo = d2?.query?.search?.[0]
    if (primo) {
      return `💬 **${primo.title}** *(Wikiquote)*:\n${primo.snippet?.replace(/<[^>]+>/g, '') || ''}\n\n🔗 [Vedi su Wikiquote](https://it.wikiquote.org/wiki/${encodeURIComponent(primo.title)})\n\n_Fonte: Wikiquote_`
    }
  } catch {}
  return 'Nessuna citazione trovata su Wikiquote.'
}

async function cercaWikisource(query: string): Promise<string> {
  try {
    const q = encodeURIComponent(query)
    const r = await fetch(`https://it.wikisource.org/w/api.php?action=query&list=search&srsearch=${q}&format=json&origin=*&utf8=1&srlimit=3`)
    const d = await r.json()
    const results = d?.query?.search || []
    if (results.length > 0) {
      const lista = results.map((res: any) =>
        `• **${res.title}** — ${res.snippet?.replace(/<[^>]+>/g, '').slice(0, 100)}...`
      ).join('\n')
      return `📜 **Testi trovati su Wikisource**:\n${lista}\n\n🔗 [Cerca su Wikisource](https://it.wikisource.org/w/index.php?search=${q})\n\n_Fonte: Wikisource_`
    }
  } catch {}
  return 'Nessun testo trovato su Wikisource.'
}

async function cercaEuropeana(query: string): Promise<string> {
  try {
    const q = encodeURIComponent(query)
    const r = await fetch(`https://api.europeana.eu/record/v2/search.json?query=${q}&rows=3&profile=minimal&wskey=api2demo&qf=LANGUAGE:it`)
    if (r.ok) {
      const d = await r.json()
      const items = d?.items || []
      if (items.length > 0) {
        const lista = items.map((item: any) => {
          const titolo = Array.isArray(item.title) ? item.title[0] : item.title || 'Senza titolo'
          const tipo = Array.isArray(item.type) ? item.type[0] : item.type || ''
          return `• **${titolo}** ${tipo ? `_(${tipo})_` : ''}`
        }).join('\n')
        return `🏛️ **Patrimonio culturale su Europeana**:\n${lista}\n\n🔗 [Cerca su Europeana](https://www.europeana.eu/it/search?query=${q})\n\n_Fonte: Europeana — Patrimonio culturale europeo_`
      }
    }
  } catch {}
  return 'Nessun risultato trovato su Europeana.'
}

// Cerca in un file della libreria
function cercaInFile(dati: any, domanda: string, nomeFile: string, nomeVisuale: string): string {
  const q = domanda.toLowerCase()
  const risultati: string[] = []

  if (dati?.materie) {
    const MATERIE_KW: Record<string, string[]> = {
      'Italiano': ['italiano','grammatica','scrittura','lettura','testo','poesia','letteratura'],
      'Storia': ['storia','guerra','rivoluzione','medioevo','romana','greca','rinascimento','fascismo','civiltà'],
      'Geografia': ['geografia','clima','territorio','continente','montagna','fiume','popolazione'],
      'Matematica': ['matematica','numeri','calcolo','geometria','frazioni','percentuale','algebra'],
      'Scienze': ['scienze','biologia','chimica','corpo','animali','piante','ecosistema','energia'],
      'Arte': ['arte','pittura','scultura','disegno','colore'],
      'Musica': ['musica','canto','strumento','ritmo','melodia'],
      'Ed. Fisica': ['educazione fisica','motoria','sport','movimento'],
      'Inglese': ['inglese','english','lingua straniera'],
      'Tecnologia': ['tecnologia','informatica','computer','coding','digitale'],
      'Ed. Civica': ['cittadinanza','costituzione','diritti','doveri','democrazia'],
      'Religione': ['religione','bibbia','vangelo','chiesa','fede'],
    }
    const CLASSI_KW: Record<string, string[]> = {
      'prima': ['classe prima','1°','1ª','primo anno'],
      'seconda': ['classe seconda','2°','2ª','secondo anno'],
      'terza': ['classe terza','3°','3ª','terzo anno'],
      'quarta': ['classe quarta','4°','4ª','quarto anno'],
      'quinta': ['classe quinta','5°','5ª','quinto anno'],
    }
    const materie = Object.entries(MATERIE_KW)
      .filter(([, kws]) => kws.some(k => { const re = new RegExp(`\\b${k}\\b`, 'i'); return re.test(q) }))
      .map(([m]) => m)
    const classi = Object.entries(CLASSI_KW)
      .filter(([, kws]) => kws.some(k => q.includes(k)))
      .map(([c]) => c)
    const tipo = nomeFile.includes('primaria') ? 'Primaria' : 'Secondaria'
    for (const [materia, datiMateria] of Object.entries(dati.materie as Record<string, any>)) {
      if (materie.length > 0 && !materie.includes(materia)) continue
      for (const [classe, datiClasse] of Object.entries((datiMateria as any).classi || {})) {
        if (classi.length > 0 && !classi.includes(classe)) continue
        const traguardi = (datiClasse as any).traguardi || []
        const obiettivi = (datiClasse as any).obiettivi || []
        const lista = traguardi.length ? traguardi : obiettivi
        if (lista.length > 0) {
          risultati.push(`🎯 **${materia}** — Classe ${classe} (${tipo})\n${lista.slice(0, 4).map((t: string) => `• ${t}`).join('\n')}`)
        }
      }
    }
  } else if (dati?.pages) {
    const ACRONIMI: Record<string, string[]> = {
      'pei': ['PEI','piano educativo individualizzato'],
      'pdp': ['PDP','piano didattico personalizzato'],
      'bes': ['BES','bisogni educativi speciali'],
      'dsa': ['DSA','disturbi specifici apprendimento'],
      'icf': ['ICF','classificazione internazionale funzionamento'],
      'uda': ['UDA','unità di apprendimento'],
      'glo': ['GLO','gruppo di lavoro operativo'],
    }
    const qTrim = q.trim()
    const termini = ACRONIMI[qTrim] || [domanda]
    const parole = termini.join(' ').toLowerCase().split(' ').filter((w: string) => w.length > 1)
    const pagineConScore = dati.pages.map((pagina: any) => {
      const testo = (pagina.text || '').toLowerCase()
      let score = 0
      for (const p of parole) {
        const regex = new RegExp(`\\b${p}\\b`, 'gi')
        const matches = testo.match(regex)
        score += matches ? matches.length * 2 : 0
      }
      return { ...pagina, score }
    }).filter((p: any) => p.score > 0)
      .sort((a: any, b: any) => b.score - a.score)
      .slice(0, 2)
    for (const pagina of pagineConScore) {
      const testo = pagina.text || ''
      const idx = testo.toLowerCase().indexOf(parole[0] || '')
      const inizio = Math.max(0, idx - 100)
      const fine = Math.min(testo.length, idx + 600)
      const estratto = testo.slice(inizio, fine).replace(/\n/g, ' ').trim()
      risultati.push(`📄 *pag. ${pagina.page_number || ''}*:\n"...${estratto}..."`)
    }
  }
  // Struttura sezioni (es. inclusione_didattica.json)
  if (dati?.sezioni) {
    const parole = q.split(' ').filter((w: string) => w.length > 1)
    for (const sezione of Object.values(dati.sezioni as Record<string, any>)) {
      const contenuti = (sezione as any).contenuti || []
      for (const contenuto of contenuti) {
        const testo = (contenuto.titolo + ' ' + contenuto.testo).toLowerCase()
        const match = parole.filter((p: string) => testo.includes(p)).length
        if (match >= 1) {
          risultati.push(`📋 **${contenuto.titolo}** *(${(sezione as any).titolo})*:\n${contenuto.testo.slice(0, 450)}${contenuto.testo.length > 450 ? '...' : ''}`)
          if (risultati.length >= 3) break
        }
      }
      if (risultati.length >= 3) break
    }
  }
  if (risultati.length === 0) return `Nessun risultato trovato in **${nomeVisuale}** per "${domanda}".`
  return risultati.slice(0, 3).join('\n\n') + `\n\n_Fonte: ${nomeVisuale}_`
}

function sommarioFile(dati: any, nome: string): string {
  if (dati?.sezioni) {
    const sezioni = Object.values(dati.sezioni as Record<string, any>)
    return `📋 **${nome}**\n\n**Sezioni disponibili:**\n${sezioni.map((s: any) => `• ${s.titolo}`).join('\n')}\n\nCerca un argomento — es. "PEI", "DSA", "metodologie inclusive", "ICF"`
  }
  if (dati?.materie) {
    const materie = Object.keys(dati.materie)
    const classi = new Set<string>()
    for (const m of Object.values(dati.materie as Record<string, any>)) {
      Object.keys(m.classi || {}).forEach((c: string) => classi.add(c))
    }
    return `📋 **${nome}**\n\n**Materie disponibili:**\n${materie.map(m => `• ${m}`).join('\n')}\n\n**Classi:**\n${[...classi].map(c => `• Classe ${c}`).join('\n')}\n\nCerca un argomento specifico!`
  }
  if (dati?.pages) {
    return `📋 **${nome}**\n\nDocumento di ${dati.pages.length} pagine.\n\nCerca qualsiasi argomento — es. "PEI", "valutazione", "programmazione"`
  }
  return `📋 **${nome}**\n\nScrivi una domanda per cercare nel documento.`
}

// ═══════════════════════════════════════
// COMPONENTE PRINCIPALE
// ═══════════════════════════════════════

export function AssistenteChat() {
  const [aperto, setAperto] = useState(false)
  const [vista, setVista] = useState<'menu' | 'chat'>('menu')
  const [filesLibreria, setFilesLibreria] = useState<FileLibreria[]>([])
  const [fileAttivo, setFileAttivo] = useState<FileLibreria | null>(null)
  const [fonteAttiva, setFonteAttiva] = useState<Fonte | null>(null)
  const [messaggi, setMessaggi] = useState<Messaggio[]>([])
  const [input, setInput] = useState('')
  const [caricando, setCaricando] = useState(false)
  const msgRef = useRef<HTMLDivElement>(null)

  useEffect(() => {
    if (aperto && filesLibreria.length === 0) {
      caricaIndice()
    }
    if (aperto) {
      setVista('menu')
      setFileAttivo(null)
      setFonteAttiva(null)
      setMessaggi([])
    }
  }, [aperto])

  useEffect(() => {
    if (msgRef.current) msgRef.current.scrollTop = msgRef.current.scrollHeight
  }, [messaggi])

  async function caricaIndice() {
    let files = ['programmazione-primaria.json', 'programmazione-secondaria.json']
    try {
      const r = await fetch(LIBRERIA_BASE + 'indice.json')
      if (r.ok) {
        const indice = await r.json()
        if (indice?.files?.length) files = indice.files
      }
    } catch {}
    setFilesLibreria(files.map(f => ({
      nome: f.replace('.json', '').replace(/_/g, ' ').replace(/-/g, ' ').replace(/^\w/, (c: string) => c.toUpperCase()),
      file: f,
      emoji: getEmoji(f)
    })))
  }

  async function apriFile(f: FileLibreria) {
    setFileAttivo(f)
    setFonteAttiva(null)
    setVista('chat')
    setCaricando(true)
    setMessaggi([{ ruolo: 'assistente', testo: '', loading: true }])
    try {
      const r = await fetch(LIBRERIA_BASE + f.file)
      if (r.ok) {
        const dati = await r.json()
        setMessaggi([{ ruolo: 'assistente', testo: sommarioFile(dati, f.nome) }])
      }
    } catch {
      setMessaggi([{ ruolo: 'assistente', testo: '❌ Errore nel caricamento.' }])
    }
    setCaricando(false)
  }

  async function apriFonte(f: Fonte) {
    setFonteAttiva(f)
    setFileAttivo(null)
    setVista('chat')
    setMessaggi([{
      ruolo: 'assistente',
      testo: `${f.emoji} **${f.nome}**\n\n${f.descrizione}\n\nCosa vuoi cercare?`
    }])
  }

  function tornaAlMenu() {
    setVista('menu')
    setFileAttivo(null)
    setFonteAttiva(null)
    setMessaggi([])
    setInput('')
  }

  async function invia() {
    if (!input.trim() || caricando) return
    const domanda = input.trim()
    setInput('')
    setCaricando(true)
    setMessaggi(prev => [
      ...prev,
      { ruolo: 'utente', testo: domanda },
      { ruolo: 'assistente', testo: '', loading: true }
    ])

    let risposta = ''
    try {
      if (fileAttivo) {
        const r = await fetch(LIBRERIA_BASE + fileAttivo.file)
        if (r.ok) {
          const dati = await r.json()
          risposta = cercaInFile(dati, domanda, fileAttivo.file, fileAttivo.nome)
        }
      } else if (fonteAttiva) {
        switch (fonteAttiva.id) {
          case 'wikipedia': risposta = await cercaWikipedia(domanda); break
          case 'wiktionary': risposta = await cercaWiktionary(domanda); break
          case 'wikiquote': risposta = await cercaWikiquote(domanda); break
          case 'wikisource': risposta = await cercaWikisource(domanda); break
          case 'europeana': risposta = await cercaEuropeana(domanda); break
          default: risposta = await cercaWikipedia(domanda)
        }
      }
    } catch {
      risposta = '❌ Errore nella ricerca. Riprova.'
    }

    setMessaggi(prev => [...prev.slice(0, -1), { ruolo: 'assistente', testo: risposta }])
    setCaricando(false)
  }

  function formattaTesto(testo: string) {
    return testo
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/_(.*?)_/g, '<em>$1</em>')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" style="color:#1e3a6e;text-decoration:underline">$1</a>')
      .replace(/\n/g, '<br/>')
  }

  const fonteCorrente = fileAttivo?.nome || fonteAttiva?.nome || ''

  return (
    <>
      {/* Bottone */}
      <button onClick={() => setAperto(!aperto)}
        style={{
          position: 'fixed', bottom: 24, right: 24, zIndex: 9999,
          width: 56, height: 56, borderRadius: '50%',
          background: 'linear-gradient(135deg, #1e3a6e, #3a5bbf)',
          border: 'none', cursor: 'pointer',
          boxShadow: '0 4px 20px rgba(30,58,110,0.4)',
          display: 'flex', alignItems: 'center', justifyContent: 'center',
          fontSize: 24, transition: 'transform .2s',
        }}
        onMouseEnter={e => (e.currentTarget.style.transform = 'scale(1.1)')}
        onMouseLeave={e => (e.currentTarget.style.transform = 'scale(1)')}
        title="Biblioteca Digitale LessonyNet">
        {aperto ? '✕' : '📚'}
      </button>

      {aperto && (
        <div style={{
          position: 'fixed', bottom: 92, right: 24, zIndex: 9998,
          width: 390, height: 580, background: '#fff',
          borderRadius: 16, boxShadow: '0 8px 40px rgba(0,0,0,0.15)',
          border: '1px solid #e8e5de', display: 'flex', flexDirection: 'column',
          overflow: 'hidden', fontFamily: 'var(--font-body, system-ui)',
        }}>
          {/* Header */}
          <div style={{ background: 'linear-gradient(135deg, #1e3a6e, #3a5bbf)', padding: '12px 14px', display: 'flex', alignItems: 'center', gap: 10 }}>
            <div style={{ fontSize: 22 }}>📚</div>
            <div style={{ flex: 1 }}>
              <div style={{ color: '#fff', fontWeight: 700, fontSize: 13 }}>Biblioteca Digitale LessonyNet</div>
              <div style={{ color: 'rgba(255,255,255,0.7)', fontSize: 10 }}>
                {vista === 'menu' ? 'Scegli una fonte per iniziare' : fonteCorrente}
              </div>
            </div>
            <button onClick={() => setAperto(false)}
              style={{ background: 'none', border: 'none', color: 'rgba(255,255,255,0.7)', cursor: 'pointer', fontSize: 18 }}>
              ✕
            </button>
          </div>

          {/* Vista MENU */}
          {vista === 'menu' && (
            <div style={{ flex: 1, overflowY: 'auto', padding: '12px 14px', background: '#f7f5f0' }}>

              {/* Fonti esterne */}
              <p style={{ fontSize: 11, fontWeight: 700, color: '#aaa', textTransform: 'uppercase', letterSpacing: '0.08em', marginBottom: 8 }}>Fonti esterne</p>
              <div style={{ display: 'flex', flexDirection: 'column', gap: 6, marginBottom: 14 }}>
                {FONTI.filter(f => f.id !== 'libreria').map(f => (
                  <div key={f.id} onClick={() => apriFonte(f)}
                    style={{
                      background: '#fff', border: `1px solid ${f.colore}22`, borderRadius: 10,
                      padding: '10px 12px', cursor: 'pointer', display: 'flex', alignItems: 'center', gap: 10,
                      transition: 'all .15s'
                    }}
                    onMouseEnter={e => { (e.currentTarget as HTMLElement).style.borderColor = f.colore; (e.currentTarget as HTMLElement).style.background = `${f.colore}08` }}
                    onMouseLeave={e => { (e.currentTarget as HTMLElement).style.borderColor = `${f.colore}22`; (e.currentTarget as HTMLElement).style.background = '#fff' }}>
                    <span style={{ fontSize: 22 }}>{f.emoji}</span>
                    <div style={{ flex: 1 }}>
                      <div style={{ fontSize: 13, fontWeight: 600, color: '#1a1a1a' }}>{f.nome}</div>
                      <div style={{ fontSize: 11, color: '#888' }}>{f.descrizione}</div>
                    </div>
                    <span style={{ fontSize: 12, color: '#ccc' }}>→</span>
                  </div>
                ))}
              </div>

              {/* Libreria LessonyNet */}
              <p style={{ fontSize: 11, fontWeight: 700, color: '#aaa', textTransform: 'uppercase', letterSpacing: '0.08em', marginBottom: 8 }}>Libreria LessonyNet</p>
              <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
                {filesLibreria.length === 0 ? (
                  <p style={{ color: '#aaa', fontSize: 12, textAlign: 'center', padding: 12 }}>⏳ Caricamento...</p>
                ) : filesLibreria.map(f => (
                  <div key={f.file} onClick={() => apriFile(f)}
                    style={{
                      background: '#fff', border: '1px solid #e8e5de', borderRadius: 10,
                      padding: '10px 12px', cursor: 'pointer', display: 'flex', alignItems: 'center', gap: 10,
                    }}
                    onMouseEnter={e => { (e.currentTarget as HTMLElement).style.borderColor = '#1e3a6e'; (e.currentTarget as HTMLElement).style.background = '#e8eef8' }}
                    onMouseLeave={e => { (e.currentTarget as HTMLElement).style.borderColor = '#e8e5de'; (e.currentTarget as HTMLElement).style.background = '#fff' }}>
                    <span style={{ fontSize: 20 }}>{f.emoji}</span>
                    <div style={{ flex: 1 }}>
                      <div style={{ fontSize: 13, fontWeight: 600, color: '#1a1a1a' }}>{f.nome}</div>
                    </div>
                    <span style={{ fontSize: 12, color: '#ccc' }}>→</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Vista CHAT */}
          {vista === 'chat' && (
            <>
              {/* Barra navigazione */}
              <div style={{ padding: '7px 12px', background: '#fff', borderBottom: '1px solid #e8e5de', display: 'flex', gap: 6 }}>
                <button onClick={tornaAlMenu}
                  style={{ fontSize: 12, color: '#1e3a6e', background: '#e8eef8', border: 'none', borderRadius: 8, padding: '5px 12px', cursor: 'pointer', fontFamily: 'inherit', fontWeight: 600 }}>
                  ← Menu
                </button>
                {fonteAttiva && (
                  <span style={{ fontSize: 11, color: '#888', display: 'flex', alignItems: 'center', gap: 4 }}>
                    {fonteAttiva.emoji} {fonteAttiva.nome}
                  </span>
                )}
                {fileAttivo && (
                  <span style={{ fontSize: 11, color: '#888', display: 'flex', alignItems: 'center', gap: 4 }}>
                    {fileAttivo.emoji} {fileAttivo.nome}
                  </span>
                )}
              </div>

              {/* Messaggi */}
              <div ref={msgRef} style={{
                flex: 1, overflowY: 'auto', padding: '12px 14px',
                display: 'flex', flexDirection: 'column', gap: 10, background: '#f7f5f0'
              }}>
                {messaggi.map((m, i) => (
                  <div key={i} style={{ display: 'flex', justifyContent: m.ruolo === 'utente' ? 'flex-end' : 'flex-start' }}>
                    <div style={{
                      maxWidth: '88%',
                      background: m.ruolo === 'utente' ? '#1e3a6e' : '#fff',
                      color: m.ruolo === 'utente' ? '#fff' : '#1a1a1a',
                      borderRadius: m.ruolo === 'utente' ? '12px 12px 2px 12px' : '12px 12px 12px 2px',
                      padding: '10px 13px', fontSize: 13, lineHeight: 1.6,
                      boxShadow: '0 1px 4px rgba(0,0,0,0.08)',
                      border: m.ruolo === 'assistente' ? '1px solid #e8e5de' : 'none'
                    }}>
                      {m.loading
                        ? <span style={{ color: '#888' }}>⏳ Ricerca in corso...</span>
                        : <span dangerouslySetInnerHTML={{ __html: formattaTesto(m.testo) }} />
                      }
                    </div>
                  </div>
                ))}
              </div>

              {/* Input */}
              <div style={{ padding: '10px 12px', background: '#fff', borderTop: '1px solid #e8e5de', display: 'flex', gap: 8 }}>
                <input
                  value={input}
                  onChange={e => setInput(e.target.value)}
                  onKeyDown={e => e.key === 'Enter' && !e.shiftKey && invia()}
                  placeholder={
                    fileAttivo ? `Cerca in ${fileAttivo.nome}...` :
                    fonteAttiva ? `Cerca su ${fonteAttiva.nome}...` :
                    'Scrivi la tua ricerca...'
                  }
                  disabled={caricando}
                  style={{
                    flex: 1, padding: '8px 12px', border: '1.5px solid #e0ddd6',
                    borderRadius: 10, fontSize: 13, fontFamily: 'inherit',
                    outline: 'none', background: '#f7f5f0', color: '#1a1a1a'
                  }}
                />
                <button onClick={invia} disabled={caricando || !input.trim()}
                  style={{
                    background: caricando || !input.trim() ? '#ccc' : '#1e3a6e',
                    color: '#fff', border: 'none', borderRadius: 10,
                    padding: '8px 14px', cursor: caricando || !input.trim() ? 'not-allowed' : 'pointer', fontSize: 16
                  }}>
                  ➤
                </button>
              </div>
            </>
          )}
        </div>
      )}
    </>
  )
}
